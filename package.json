{
  "name": "portfolio-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @portfolio/web dev",
    "dev:api": "cd apps/api && go run ./cmd/server/",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "prod:docker": "docker compose up --build -d",
    "prod:docker:down": "docker compose down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "build": "pnpm --filter @portfolio/web build",
    "lint": "pnpm --filter @portfolio/web lint"
  }
}
